{
  "name": "universal-harness",
  "version": "0.1.0",
  "private": false,
  "description": "Runtime-agnostic command harness with modes, retries, timeouts, and JSON reports.",
  "license": "MIT",
  "scripts": {
    "harness": "node scripts/harness-runner.js --mode quick",
    "harness:quick": "node scripts/harness-runner.js --mode quick",
    "harness:full": "node scripts/harness-runner.js --mode full",
    "harness:ci": "node scripts/harness-runner.js --pipeline ci",
    "harness:history": "node scripts/harness-runner.js --history",
    "harness:compare": "node scripts/harness-runner.js --compare latest",
    "harness:watch": "node scripts/harness-scheduler.js --interval 30s --mode quick",
    "harness:watch:ci": "node scripts/harness-scheduler.js --interval 30s --pipeline ci",
    "harness:json": "node scripts/harness-runner.js --mode full --json"
  },
  "engines": {
    "node": ">=18"
  }
}
