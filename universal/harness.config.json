{
  "resultDir": "harness/results",
  "defaultMode": "quick",
  "modes": {
    "quick": ["lint", "unit", "smoke"],
    "full": ["install-check", "lint", "unit", "build", "smoke"]
  },
  "pipelines": {
    "ci": [
      {
        "name": "quality",
        "mode": "quick",
        "failFast": true
      },
      {
        "name": "build",
        "check": "build",
        "failFast": true
      }
    ],
    "release": [
      {
        "name": "full-gate",
        "mode": "full",
        "failFast": true
      }
    ]
  },
  "checks": [
    {
      "id": "install-check",
      "name": "Install Check",
      "tags": ["system"],
      "command": "npm --version",
      "timeoutMs": 30000,
      "retries": 0,
      "required": true
    },
    {
      "id": "lint",
      "name": "Lint",
      "tags": ["quality"],
      "command": "npm run lint --if-present",
      "timeoutMs": 120000,
      "retries": 0,
      "required": false
    },
    {
      "id": "unit",
      "name": "Unit Tests",
      "tags": ["test"],
      "command": "npm test --if-present",
      "timeoutMs": 120000,
      "retries": 0,
      "required": false
    },
    {
      "id": "build",
      "name": "Build",
      "tags": ["build"],
      "command": "npm run build --if-present",
      "timeoutMs": 180000,
      "retries": 0,
      "required": false
    },
    {
      "id": "smoke",
      "name": "Smoke Check",
      "tags": ["smoke"],
      "command": "node examples/checks/sample-pass.js",
      "timeoutMs": 30000,
      "retries": 1,
      "required": true
    }
  ]
}
