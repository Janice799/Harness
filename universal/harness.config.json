{
  "resultDir": "harness/results",
  "defaultMode": "quick",
  "modes": {
    "quick": ["lint", "unit", "smoke"],
    "full": ["install-check", "lint", "unit", "build", "smoke"]
  },
  "checks": [
    {
      "id": "install-check",
      "name": "Install Check",
      "command": "npm --version",
      "timeoutMs": 30000,
      "retries": 0,
      "required": true
    },
    {
      "id": "lint",
      "name": "Lint",
      "command": "npm run lint --if-present",
      "timeoutMs": 120000,
      "retries": 0,
      "required": false
    },
    {
      "id": "unit",
      "name": "Unit Tests",
      "command": "npm test --if-present",
      "timeoutMs": 120000,
      "retries": 0,
      "required": false
    },
    {
      "id": "build",
      "name": "Build",
      "command": "npm run build --if-present",
      "timeoutMs": 180000,
      "retries": 0,
      "required": false
    },
    {
      "id": "smoke",
      "name": "Smoke Check",
      "command": "node examples/checks/sample-pass.js",
      "timeoutMs": 30000,
      "retries": 1,
      "required": true
    }
  ]
}
